        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {
    if (!gs.getSession().isInteractive() && current.sys_class_name == "u_customer_provider_equipment") {
        return;
    } else {
        var regex = new RegExp("^[A-Za-z0-9\-_.]*$");
        var res = regex.test(current.u_hostname);
        if (!res || current.u_hostname.length > 51) {
            gs.addErrorMessage('Hostname - Invalid input: Only alphanumeric characters, hyphens, underscores, and periods allowed. 51 character max length.');
            current.setAbortAction(true);
        }

    }



})(current, previous);]]></script>
