        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    // Add your code here
    var time = new GlideDateTime();
    g_scratchpad.delayedStartTime = false;
    g_scratchpad.delayedEndTime = false;

    var delayStartTime = gs.dateDiff(current.start_date, current.work_start, true);
    if (delayStartTime > 600) {
        g_scratchpad.delayedStartTime = true;
    }
    var delayEndTime = gs.dateDiff(current.end_date, time, true);    
    if (delayEndTime > -600) {
        g_scratchpad.delayedEndTime = true;
    }
})(current, previous);]]></script>
