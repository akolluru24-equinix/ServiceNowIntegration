<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_script_fix">
    <sys_script_fix action="INSERT_OR_UPDATE">
        <before>false</before>
        <description> VM discovery for Finland and Japan vCenters</description>
        <name>Existing VMware Virtual Machine CI's</name>
        <record_for_rollback>true</record_for_rollback>
        <script><![CDATA[var grRetire = new GlideRecord('cmdb_ci_vmware_instance');
grRetire.addEncodedQuery('discovery_source=ServiceNow^sys_created_byLIKEmidserver^u_operating_unitINFI,JP^install_status!=7^operational_status!=6');// Japan, FIN query
grRetire.query();
while (grRetire.next()) {
    grRetire.setWorkflow(false);//Ignore BR
    grRetire.skip_sync = true;
    grRetire.install_status = 7;//Retire
    grRetire.operational_status = 6;//Retire
    grRetire.u_active_flag = false;
    grRetire.update();
}]]></script>
