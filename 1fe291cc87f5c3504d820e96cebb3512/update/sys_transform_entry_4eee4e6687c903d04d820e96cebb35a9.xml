        <source_script><![CDATA[answer = (function transformEntry(source) {

    var accountNum = source.u_related_accnt_num;

    if (JSUtil.nil(accountNum)) {
        return "";
    }

    var accountGr = new GlideRecord("customer_account");
    accountGr.addQuery("u_account_number", accountNum);
    accountGr.setLimit(1);
    accountGr.query();

    return accountGr.next() ? accountGr.getUniqueValue() : "";
	
})(source);]]></source_script>
