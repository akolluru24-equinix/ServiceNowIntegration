        <source_script><![CDATA[answer = (function transformEntry(source) {

    var spaceId = source.u_x_unique_space_id;

    if (JSUtil.nil(spaceId)) {
        return "";
    }

    var countryGr = new GlideRecord("u_unique_space_id");
    countryGr.addQuery("u_uid", spaceId);
    countryGr.setLimit(1);
    countryGr.query();

    return countryGr.next() ? countryGr.getUniqueValue() : "";
	
})(source);]]></source_script>
