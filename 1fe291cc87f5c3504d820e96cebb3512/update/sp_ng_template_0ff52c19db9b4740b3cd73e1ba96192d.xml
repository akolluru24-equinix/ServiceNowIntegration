        <template><![CDATA[<a ng-if="item.items.length == 0 && !item.scriptedItems && item.short_description" ng-href={{item.href}} ng-click="clickMenu1($event, item);c.setCurrentActiveMenu($event,item.sys_id,item.href,item.url_target)" target="{{item.url_target}}" title="{{item.hint}}">

  <fa ng-if="item.glyph" name="{{::item.glyph}}"></fa>
  <span class="menu-item-title" ng-bind-html="::item.label"></span> 
  
  <!--Inserted to meet the development from MPE-045 story><-->
  <span ng-if="item.u_badge" class="badge-menu badge-pill"  ng-class="{'setBetaBadge': checkBetaBadge(item.u_badge), 'setNewBadge': checkNewBadge(item.u_badge)}">{{item.u_badge}}</span>
    <p class="menu-description" ng-if="item.short_description"> {{item.short_description}}</p>
  
</a>
<!--Inserted to meet the development from MSSI-1033 story><-->
<a ng-if="item.items.length == 0 && !item.scriptedItems && !item.short_description" ng-href="{{item.href}}" ng-click="c.setCurrentActiveMenu($event,item.sys_id,item.href)" target="{{item.url_target}}" title="{{item.hint}}">
  <div class="sp-menu-text-wrapper" title={{::item.label}}>
    <fa ng-if="item.glyph" name="{{::item.glyph}}"></fa>
    <span ng-bind-html="item.label" class="m-r-small"></span>
  </div>
  <eq-badge content="${Beta}" size="small" type="primary" ng-if="c.data.reportingMenu == item.sys_id"></eq-badge>
</a>

<a role="button" ng-if="item.items.length > 0 && item.first_level" href="javascript:void(0)" class="dropdown-toggle sp-menu-has-items" aria-controls="menu-apply" data-toggle="dropdown" aria-haspopup="true" title="{{item.hint}}">
  <fa ng-if="item.glyph" name="{{::item.glyph}}"></fa>
  <div class="sp-menu-text-wrapper" title={{::item.label}}>
  <span ng-bind-html=item.label></span> <!--<i ng-if="item.items[0].items.length !== 0" class="fa fa-chevron-down" style="font-size: 9px"></i>-->
  </div>
  <span ng-if="item.first_level" class="d-flex">  
  <eq-icon
  		name="chevron-down-outline"
  		style="--size: 16px; --fill: #2a303c;"
        chevron-directive
  		>
  </eq-icon>    
  </span>
</a>
<ul ng-if="item.items.length > 0 && !item.first_level" class="category-list items-list" role="group" id="menu-apply" >  
  <li ng-repeat="item in item.items" class="has-item " ng-include="'mspMenuTemplate'" />  
</ul>
<a role="button" ng-if="item.scriptedItems.count > 0" href="javascript:void(0)" data-toggle="dropdown" title="{{item.hint}}">
  <fa ng-if="item.glyph" name="{{::item.glyph}}"></fa>
  <span ng-bind-html="item.label" ></span>
  <span ng-if="!item.scriptedItems.omitBadge" class="label label-as-badge label-primary sp-navbar-badge-count">{{item.scriptedItems.count}}</span>
</a>
<msp-dropdown-tree role="menu" aria-label="{{::item.label}}" ng-if="item.scriptedItems.count > 0" items="item.scriptedItems.items" />]]></template>
    </sp_ng_template>
