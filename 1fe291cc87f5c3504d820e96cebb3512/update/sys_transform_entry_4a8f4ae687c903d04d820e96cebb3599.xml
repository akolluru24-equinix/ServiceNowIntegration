        <source_script><![CDATA[answer = (function transformEntry(source) {

    var parentAsset = source.u_parent_asset_num;

    if (JSUtil.nil(parentAsset)) {
        return "";
    }

    var contractItemGr = new GlideRecord("sn_customerservice_contract_item");
    contractItemGr.addQuery("u_siebel_asset_number", parentAsset);
    contractItemGr.setLimit(1);
    contractItemGr.query();

    return contractItemGr.next() ? contractItemGr.getUniqueValue() : "";
	
})(source);]]></source_script>
