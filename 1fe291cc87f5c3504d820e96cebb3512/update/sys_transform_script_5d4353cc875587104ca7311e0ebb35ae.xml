        <map display_value="LTC CI For POE">f2af0bcc87d187104ca7311e0ebb3577</map>
        <order>100</order>
        <script><![CDATA[(function runTransformScript(source, map, log, target /*undefined onStart*/ ) {

    if (JSUtil.notNil(source.sys_target_sys_id)) {
        var ci = source.sys_target_sys_id;
        var assetId = source.u_asset_num;
        var contractitem;
        var contractItemGr = new GlideRecord("sn_customerservice_contract_item");
        contractItemGr.addQuery("u_siebel_asset_number", assetId);
        contractItemGr.setLimit(1);
        contractItemGr.query();
        if (contractItemGr.next()) {
            contractitem = contractItemGr.sys_id;
        }
        var relGr = new GlideRecord("contract_rel_ci");
        relGr.initialize();
        relGr.contract = contractitem;
        relGr.ci_item = ci;
        relGr.insert();
    }


})(source, map, log, target);]]></script>
