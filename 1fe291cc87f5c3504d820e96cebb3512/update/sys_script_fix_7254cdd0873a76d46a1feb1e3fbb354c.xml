    <sys_script_fix action="INSERT_OR_UPDATE">
        <before>false</before>
        <description>De-activating Case schedules created due to script error.</description>
        <name>Case schedule deactivation</name>
        <record_for_rollback>true</record_for_rollback>
        <script><![CDATA[var grSCCS = new GlideRecord('sn_customerservice_case_schedule');
grSCCS.addEncodedQuery("u_active=true^u_backend=false^u_ticket_reference.account.nameISEMPTY");
grSCCS.setLimit(10000);
grSCCS.query();
while (grSCCS.next()) {
	grSCCS.setValue("u_active", "false");
	grSCCS.update();
}]]></script>
