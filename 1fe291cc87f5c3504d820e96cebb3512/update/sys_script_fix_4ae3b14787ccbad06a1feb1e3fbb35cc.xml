    <sys_script_fix action="INSERT_OR_UPDATE">
        <before>false</before>
        <description>EC2-2080: Enable Monitoring in Japan and Spain EMS Portal</description>
        <name>Eqix update Account ModuleCache</name>
        <record_for_rollback>true</record_for_rollback>
        <script><![CDATA[var gr = new GlideRecord('sn_customerservice_contract_item');
gr.addEncodedQuery("u_siebel_asset_status=active^account.u_operating_unit=JP^ORaccount.u_operating_unit=ES^u_order_line_item.u_product=588d99104f6c6b00537a09fd0210c712");
gr.query();

while (gr.next()) {
	
    var ac = new EQIX_Customer_Permissions();
    ac.updateAccountModuleCache(gr.account);
	if (!gs.nil(gr.u_sub_account)) {
		ac.updateAccountModuleCache(gr.u_sub_account);
	}
}]]></script>
