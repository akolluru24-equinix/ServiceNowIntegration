        <description>Set the u_operating_unity field according to the associated Host</description>
        <execute_function>false</execute_function>
        <filter_condition table="u_event_management">u_event_type=1^ORu_event_type=2^u_equipmentISNOTEMPTY^ORu_equipmentVALCHANGES^NQu_operating_unit=^EQ<item display_value="Monitoring Event" endquery="false" field="u_event_type" goto="false" newquery="false" operator="=" or="false" value="1"/>
            <item display_value="Backup Event" endquery="false" field="u_event_type" goto="false" newquery="false" operator="=" or="true" value="2"/>
            <item endquery="false" field="u_equipment" goto="false" newquery="false" operator="ISNOTEMPTY" or="false" value=""/>
