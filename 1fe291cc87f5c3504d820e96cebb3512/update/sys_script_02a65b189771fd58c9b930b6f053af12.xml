        <is_rest>false</is_rest>
        <message/>
        <name>EQIX Set Event Operating Unit field</name>
        <order>100</order>
        <priority>100</priority>
        <rest_method/>
        <rest_method_text/>
        <rest_service/>
        <rest_service_text/>
        <rest_variables/>
        <role_conditions/>
        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {
    type = current.u_event_type;
    if (type == 1 || type == 2 && !gs.nil(current.u_equipment)) {
        var grCI = new GlideRecord('cmdb_ci');
        grCI.addQuery('sys_id', current.u_equipment);
        grCI.query();
        if (grCI.next()) {
            current.u_operating_unit = grCI.u_operating_unit;
            current.u_operational_scope = grCI.u_operational_scope;
			//EPE2-1036
			current.u_account = grCI.u_account;
        }
    }


})(current, previous);]]></script>
