        <name>Add to an Event Storm</name>
        <onclick>addToEventStormFromList()</onclick>
        <order>99</order>
        <script><![CDATA[function addToEventStormFromList() {
    var answer = "true";
    var eventTasksList = g_list.getChecked().toString();
    var checkedCount = g_list.getChecked().toString().split(',').length;

    if (checkedCount > 1) {
        var ga = new GlideAjax('EQIX_MonitoringEventUtilAJAX');
        ga.addParam('sysparm_name', 'eventStormSameAccount');
        ga.addParam('sysparm_event_task', eventTasksList);
        ga.getXMLWait();
        answer = ga.getAnswer();
    }
    if (answer == "true") {
        casebyEvent(eventTasksList);
    } else {
        alert(answer);
    }
}

function casebyEvent(eventTasksList) {
    //Initialize and open the dialog
    var dialog = new GlideDialogWindow("EQIX_Add_EventStorm_From_Alerts");
    dialog.setTitle(getMessage(""));
    dialog.setSize(400, 300);
    dialog.setPreference("alert_id", eventTasksList);
    dialog.render();
}]]></script>
