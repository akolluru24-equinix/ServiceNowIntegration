 if (gr.next()) {
	
     var implementer = gr.u_person_s_who_wil_implement_the_change;
     var assignee = gr.assigned_to;
     var state = gr.state;
     var user = gs.getUserID();

     if (gs.getUser().isMemberOf(parent.u_patch_execution.u_change.assignment_group.getDisplayValue()) && state != -1 && state != -2 && state != 0) {
         answer = false;
     } else if (implementer == user && (state == -6 || state == -5)) {
         answer = false;
     } else {
         answer = true;
     }
 }]]></new_condition>
